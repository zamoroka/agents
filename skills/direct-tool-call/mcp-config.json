{
  "mcpServers": {
    "chrome-devtools": {
      "command": "npx",
      "args": ["-y", "chrome-devtools-mcp@latest"]
    },
    "google-drive": {
      "command": "uv",
      "args": ["--directory", "~/.agents/mcp/mcp-google-drive", "run", "google-drive-mcp"]
    },
    "jira": {
      "command": "uv",
      "args": ["--directory", "~/.agents/mcp/mcp-jira", "run", "mcp-jira"]
    },
    "magento2-lsp-mcp": {
      "command": "magento2-lsp-mcp",
      "args": []
    }
  }
}
